generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Attachment {
  id    String @id @default(uuid())
  title String
  url   String

  event Event?

  @@map("attachments")
}

model Event {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  date        DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  bannerImageId String?     @unique @map("banner_image_id")
  bannerImage   Attachment? @relation(fields: [bannerImageId], references: [id])

  registrations Registration[]

  @@map("events")
}

model Participant {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  registrations Registration[]

  @@map("participants")
}

model Registration {
  id           String   @id @default(uuid())
  registeredAt DateTime @default(now()) @map("registered_at")

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String @map("event_id")

  participant   Participant @relation(fields: [participantId], references: [id])
  participantId String      @map("participant_id")

  @@unique([eventId, participantId])
  @@map("registrations")
}
